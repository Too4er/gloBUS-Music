<Page x:Class="gloBUS_Music.MVVM.Views.PlaylistsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="PlaylistsPage"
      Background="#FAFAFA">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="220"
                         Height="32"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Create Playlist"
                        Command="{Binding CreatePlaylistCommand}"
                        Margin="0,0,10,0"
                        Padding="12,6"
                        Background="#6200EE"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"/>

                <Button Content="Delete Playlist"
                        Command="{Binding DeletePlaylistCommand}"
                        Margin="0,0,10,0"
                        Padding="12,6"
                        Background="#B00020"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"/>

                <Button Content="Open Playlist"
                        Click="OpenPlaylist_Click"
                        Padding="12,6"
                        Background="#03DAC6"
                        Foreground="Black"
                        FontWeight="Bold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Плейлисты"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <ListBox ItemsSource="{Binding Playlists}"
                             SelectedItem="{Binding SelectedPlaylist}"
                             DisplayMemberPath="Name"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Все треки"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ListBox ItemsSource="{Binding AvailableTracks}"
                                 SelectedItem="{Binding SelectedAvailableTrack}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Artist}" Opacity="0.7"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,10">
                    <Button Content="Add to Playlist"
                            Command="{Binding AddTrackToPlaylistCommand}"
                            Margin="0,0,10,0"
                            Padding="12,6"
                            Background="#03DAC6"
                            Foreground="Black"
                            FontWeight="Bold"
                            BorderThickness="0"/>

                    <Button Content="Remove from Playlist"
                            Command="{Binding RemoveTrackFromPlaylistCommand}"
                            Padding="12,6"
                            Background="#FFB300"
                            Foreground="Black"
                            FontWeight="Bold"
                            BorderThickness="0"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="Треки выбранного плейлиста"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ListBox ItemsSource="{Binding PlaylistTracks}"
                                 SelectedItem="{Binding SelectedPlaylistTrack}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Artist}" Opacity="0.7"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>