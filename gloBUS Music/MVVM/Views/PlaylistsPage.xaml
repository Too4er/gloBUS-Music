<Page x:Class="gloBUS_Music.MVVM.Views.PlaylistsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="PlaylistsPage"
      Background="Transparent"
      UseLayoutRounding="True">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="14"
                Margin="0,0,0,12"
                Effect="{StaticResource SoftShadowEffect}">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="220"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MusicTextBoxStyle}"/>

                <Button Content="Create Playlist"
                        Command="{Binding CreatePlaylistCommand}"
                        Margin="0,0,10,0"
                        Style="{StaticResource PrimaryButtonStyle}"/>

                <Button Content="Delete Playlist"
                        Command="{Binding DeletePlaylistCommand}"
                        Margin="0,0,10,0"
                        Style="{StaticResource DangerButtonStyle}"/>

                <Button Content="Open Playlist"
                        Click="OpenPlaylist_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="12"
                    Margin="0,0,10,0"
                    Effect="{StaticResource SoftShadowEffect}">
                <StackPanel>
                    <TextBlock Text="Плейлисты"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="4,0,0,12"/>

                    <ListBox ItemsSource="{Binding Playlists}"
                             SelectedItem="{Binding SelectedPlaylist}"
                             DisplayMemberPath="Name"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource MusicListBoxItemStyle}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="12"
                        Margin="0,0,0,10"
                        Effect="{StaticResource SoftShadowEffect}">
                    <StackPanel>
                        <TextBlock Text="Все треки"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="4,0,0,12"/>

                        <ListBox ItemsSource="{Binding AvailableTracks}"
                                 SelectedItem="{Binding SelectedAvailableTrack}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource MusicListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Artist}" Opacity="0.75"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,10">
                    <Button Content="Add to Playlist"
                            Command="{Binding AddTrackToPlaylistCommand}"
                            Margin="0,0,10,0"
                            Style="{StaticResource AccentButtonStyle}"/>

                    <Button Content="Remove from Playlist"
                            Command="{Binding RemoveTrackFromPlaylistCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="12"
                        Effect="{StaticResource SoftShadowEffect}">
                    <StackPanel>
                        <TextBlock Text="Треки выбранного плейлиста"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="4,0,0,12"/>

                        <ListBox ItemsSource="{Binding PlaylistTracks}"
                                 SelectedItem="{Binding SelectedPlaylistTrack}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource MusicListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Artist}" Opacity="0.75"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>