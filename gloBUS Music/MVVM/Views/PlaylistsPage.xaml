<Page x:Class="gloBUS_Music.MVVM.Views.PlaylistsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
      xmlns:controls="clr-namespace:gloBUS_Music.MVVM.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PlaylistsPage">

    <DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель управления плейлистами -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                <Button Content="Create Playlist" Command="{Binding CreatePlaylistCommand}" Margin="5"/>
                <Button Content="Edit Playlist" Command="{Binding EditPlaylistCommand}" Margin="5"/>
            </StackPanel>

            <!-- Список плейлистов -->
            <ListBox x:Name="PlaylistsListBox" Grid.Row="1" ItemsSource="{Binding Playlists}" DisplayMemberPath="Name"
                     SelectedItem="{Binding SelectedPlaylist}" SelectionChanged="PlaylistsListBox_SelectionChanged" Margin="10"/>
        </Grid>
    </DockPanel>
</Page>
