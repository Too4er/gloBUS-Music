<Page x:Class="gloBUS_Music.MVVM.Views.TracksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
      xmlns:controls="clr-namespace:gloBUS_Music.MVVM.Controls"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TracksPage"
      Background="#FAFAFA">

    <DockPanel LastChildFill="True">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                <Button Content="Add Track" Command="{Binding AddTrackCommand}" Margin="5" Padding="10,5"
                        Background="#6200EE" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="Remove Track" Command="{Binding RemoveTrackCommand}" Margin="5" Padding="10,5"
                        Background="#B00020" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="TrackListBox"
                         Grid.Column="0"
                         ItemsSource="{Binding Tracks}"
                         SelectedItem="{Binding SelectedTrack}"
                         DisplayMemberPath="Title"
                         Margin="0,0,10,-66"
                         Background="White"
                         BorderBrush="#E0E0E0"
                         BorderThickness="1"
                         Padding="5"
                         FontSize="14">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#6200EE"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDE7F6"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Border Grid.Column="1" Padding="20" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="40,0,10,-66">
                    <StackPanel Orientation="Vertical" Margin="5" HorizontalAlignment="Center">
                        <TextBlock Text="Название" FontWeight="Bold" Margin="5,0"/>
                        <TextBox Text="{Binding NewTrack.Title, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Height="30" Margin="5"/>

                        <TextBlock Text="Исполнитель" FontWeight="Bold" Margin="5,0"/>
                        <TextBox Text="{Binding NewTrack.Artist, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Height="30" Margin="5"/>

                        <TextBlock Text="Длительность (сек)" FontWeight="Bold" Margin="5,0"/>
                        <TextBox Text="{Binding NewTrack.Duration, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Width="200" Height="30" Margin="5"
                                 InputScope="Number"/>

                        <TextBlock Text="Путь к файлу:" FontWeight="Bold" Margin="5,10,5,0"/>
                        <Button Content="Выбрать файл"
                                Command="{Binding SelectFileCommand}"
                                Padding="10,5"
                                Background="#03DAC6"
                                Foreground="Black"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Width="200"/>
                        <TextBlock Text="{Binding NewTrack.Link}" Width="200" TextWrapping="Wrap" Margin="5"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="10" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <MediaElement x:Name="AudioPlayer"
                              Grid.Row="0"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Stop"
                              Width="300"
                              Height="50"
                              HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="1" Margin="0,0,0,10" Width="400">
                    <Slider x:Name="PlaybackSlider"
                            Value="{Binding PlaybackProgress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Maximum="{Binding PlaybackDuration}"
                            Minimum="0"
                            Height="20"
                            Thumb.DragStarted="PlaybackSlider_DragStarted"
                            Thumb.DragCompleted="PlaybackSlider_DragCompleted"
                            ValueChanged="PlaybackSlider_ValueChanged"/>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding CurrentTime}"
                                   Grid.Column="0"
                                   HorizontalAlignment="Left"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding TotalTime}"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                    <Button Content="▶ Play"
                            Command="{Binding PlayTrackCommand}"
                            Margin="5"
                            Padding="10,5"
                            Background="#03DAC6"
                            Foreground="Black"
                            FontWeight="Bold"
                            BorderThickness="0"
                            IsEnabled="{Binding CanPlayTrack}"/>

                    <Button Content="⏸ Pause"
                            Command="{Binding PauseTrackCommand}"
                            Margin="5"
                            Padding="10,5"
                            Background="#FFB300"
                            Foreground="Black"
                            FontWeight="Bold"
                            BorderThickness="0"/>

                    <Button Content="⏹ Stop"
                            Command="{Binding StopTrackCommand}"
                            Margin="5"
                            Padding="10,5"
                            Background="#B00020"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>

        </Grid>
    </DockPanel>
</Page>