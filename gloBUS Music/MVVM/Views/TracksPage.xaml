<Page x:Class="gloBUS_Music.MVVM.Views.TracksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
      xmlns:controls="clr-namespace:gloBUS_Music.MVVM.Controls"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="TracksPage"
      Background="Transparent"
      UseLayoutRounding="True">

    <DockPanel LastChildFill="True">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,14">
                <Button Content="Add Track"
                        Command="{Binding AddTrackCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,10,0"/>

                <Button Content="Remove Track"
                        Command="{Binding RemoveTrackCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="10,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="8"
                        Margin="0,0,10,0"
                        Effect="{StaticResource SoftShadowEffect}">
                    <ListBox x:Name="TrackListBox"
                             ItemsSource="{Binding Tracks}"
                             SelectedItem="{Binding SelectedTrack, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             DisplayMemberPath="Title"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="4"
                             FontSize="14"
                             ItemContainerStyle="{StaticResource MusicListBoxItemStyle}"/>
                </Border>

                <Border Grid.Column="1"
                        Padding="22"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Margin="30,0,10,0"
                        Effect="{StaticResource SoftShadowEffect}">
                    <StackPanel Orientation="Vertical"
                                Margin="5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <TextBlock Text="Название (если оставить пустым — определится автоматически)"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Width="260"
                                   Margin="5,0"/>

                        <TextBox Text="{Binding NewTrack.Title, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MusicTextBoxStyle}"
                                 Width="260"
                                 Margin="5,8,5,0"/>

                        <TextBlock Text="Путь к файлу:"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="5,16,5,0"/>

                        <Button Content="Выбрать файл"
                                Command="{Binding SelectFileCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Width="260"
                                Margin="5,8,5,0"/>

                        <TextBlock Text="{Binding NewTrack.Link}"
                                   Width="260"
                                   TextWrapping="Wrap"
                                   Margin="5,12,5,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Page>