<Window x:Class="gloBUS_Music.MVVM.Views.PlaylistContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
        mc:Ignorable="d"
        Title="PlaylistContentWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding PlaylistName}" FontSize="18" Margin="10"/>

        <ListBox Grid.Row="1" x:Name="PlaylistTracksListBox" DisplayMemberPath="Title" Margin="10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Remove Track" Click="RemoveTrackFromPlaylist_Click" Margin="5"/>
            <Button Content="Close" Click="Close_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
