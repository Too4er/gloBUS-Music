<Window x:Class="gloBUS_Music.MVVM.Views.PlaylistContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
        mc:Ignorable="d"
        Title="PlaylistContentWindow"
        Height="450"
        Width="700"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Name}"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="4,0,0,12"/>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="10"
                Margin="0,0,0,12"
                Effect="{StaticResource SoftShadowEffect}">
            <ListBox Grid.Row="1"
                     x:Name="PlaylistTracksListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource MusicListBoxItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Artist}" Opacity="0.75"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Remove Track"
                    Click="RemoveTrackFromPlaylist_Click"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Content="Close"
                    Click="Close_Click"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>