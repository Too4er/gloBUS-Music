<Window x:Class="gloBUS_Music.MVVM.Views.PlaylistContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gloBUS_Music.MVVM.Views"
        mc:Ignorable="d"
        Title="PlaylistContentWindow"
        Height="450"
        Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Name}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <ListBox Grid.Row="1"
                 x:Name="PlaylistTracksListBox"
                 Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Artist}" Opacity="0.7"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Remove Track"
                    Click="RemoveTrackFromPlaylist_Click"
                    Margin="0,0,10,0"
                    Padding="12,6"
                    Background="#FFB300"
                    Foreground="Black"
                    FontWeight="Bold"
                    BorderThickness="0"/>

            <Button Content="Close"
                    Click="Close_Click"
                    Padding="12,6"
                    Background="#6200EE"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>