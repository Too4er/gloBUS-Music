<Window x:Class="gloBUS_Music.MVVM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:gloBUS_Music.MVVM.Controls"
        Title="gloBUS Music"
        Height="550"
        Width="800"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="LightBlue" SecondaryColor="Cyan" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">
        <local:NavigationMenu x:Name="NavigationMenu" Margin="0,0,10,0" />
        <local:PlayerControl x:Name="GlobalPlayerControl" DockPanel.Dock="Bottom" Margin="0,10,0,0" />

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="30"
                Effect="{StaticResource SoftShadowEffect}">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent" />
        </Border>
    </DockPanel>
</Window>