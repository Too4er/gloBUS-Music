<UserControl x:Class="gloBUS_Music.MVVM.Controls.PlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="600"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <Style x:Key="RoundSliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Ellipse Margin="1"
                                     StrokeThickness="1.4"
                                     Stroke="#CCFFFFFF">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.35,0.3"
                                                         GradientOrigin="0.3,0.25"
                                                         RadiusX="0.8"
                                                         RadiusY="0.8">
                                        <GradientStop Color="#F7FFFFFF" Offset="0"/>
                                        <GradientStop Color="#D9EFFFFB" Offset="0.28"/>
                                        <GradientStop Color="#E07BD3C9" Offset="0.72"/>
                                        <GradientStop Color="#FF5DB8AF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="7"
                                                      ShadowDepth="1"
                                                      Opacity="0.18"
                                                      Color="#4E7F87"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse Margin="4,3,4,9"
                                     Fill="#72FFFFFF"
                                     IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizontalSliderDecreaseButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Height="6"
                                VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizontalSliderIncreaseButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Height="6"
                                VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VerticalSliderDecreaseButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Width="6"
                                HorizontalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VerticalSliderIncreaseButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Width="6"
                                HorizontalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizontalRoundSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="9"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="9"/>
                            </Grid.ColumnDefinitions>

                            <Track x:Name="PART_Track"
                                   Grid.Column="1"
                                   Orientation="Horizontal"
                                   IsDirectionReversed="False"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource HorizontalSliderDecreaseButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource RoundSliderThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource HorizontalSliderIncreaseButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VerticalRoundSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="9"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="9"/>
                            </Grid.RowDefinitions>

                            <Track x:Name="PART_Track"
                                   Grid.Row="1"
                                   Orientation="Vertical"
                                   IsDirectionReversed="False"
                                   HorizontalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource VerticalSliderDecreaseButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource RoundSliderThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource VerticalSliderIncreaseButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="24"
            Padding="16"
            Effect="{StaticResource SoftShadowEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <MediaElement x:Name="AudioPlayer"
                          Grid.Row="0"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          Width="1"
                          Height="1"
                          HorizontalAlignment="Center"
                          MediaEnded="AudioPlayer_MediaEnded"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <Slider x:Name="PlaybackSlider"
                        Style="{StaticResource HorizontalRoundSliderStyle}"
                        Value="{Binding PlaybackProgress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Maximum="{Binding PlaybackDuration}"
                        Minimum="0"
                        IsMoveToPointEnabled="True"
                        Thumb.DragStarted="PlaybackSlider_DragStarted"
                        Thumb.DragCompleted="PlaybackSlider_DragCompleted"
                        ValueChanged="PlaybackSlider_ValueChanged"/>

                <Grid Margin="2,6,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding CurrentTime}"
                               Grid.Column="0"
                               HorizontalAlignment="Left"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"/>

                    <TextBlock Text="{Binding TotalTime}"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Grid>
                    <Button Content="▶ Play"
                            Command="{Binding PlayTrackCommand}"
                            IsEnabled="{Binding CanPlayTrack}"
                            Margin="5"
                            Padding="18,10">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="⏸ Pause"
                            Command="{Binding PauseTrackCommand}"
                            Margin="5"
                            Padding="18,10">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Button Content="⏹ Stop"
                        Command="{Binding StopTrackCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Margin="5"
                        Padding="18,10"/>

                <Grid Margin="6,0,0,0">
                    <Button x:Name="VolumeButton"
                            Style="{StaticResource SurfaceButtonStyle}"
                            Margin="5"
                            Padding="14,10"
                            MinWidth="52"
                            Click="VolumeButton_Click"
                            MouseEnter="VolumeButton_MouseEnter"
                            MouseLeave="VolumeButton_MouseLeave">
                        <TextBlock Text="{Binding VolumeIcon}" FontSize="17"/>
                    </Button>

                    <Popup x:Name="VolumePopup"
                           PlacementTarget="{Binding ElementName=VolumeButton}"
                           Placement="Top"
                           VerticalOffset="-8"
                           AllowsTransparency="True"
                           StaysOpen="True"
                           PopupAnimation="Fade">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="14"
                                Effect="{StaticResource SoftShadowEffect}"
                                MouseEnter="VolumePopup_MouseEnter"
                                MouseLeave="VolumePopup_MouseLeave">
                            <StackPanel HorizontalAlignment="Center">
                                <Slider Style="{StaticResource VerticalRoundSliderStyle}"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Orientation="Vertical"
                                        Height="130"
                                        TickFrequency="0.05"
                                        IsMoveToPointEnabled="True"/>

                                <TextBlock Text="{Binding VolumePercentText}"
                                           Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>